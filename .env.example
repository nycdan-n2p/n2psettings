# ── Required ──────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local — it contains secrets.

# Anthropic API key — used by the Concierge agent and CDR analyzer
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── net2phone API base URLs ────────────────────────────────────────────────────
# These default to production; override for staging/local proxy environments.

N2P_API_URL=https://app.net2phone.com/
N2P_API_V2_URL=https://app.net2phone.com/api/v2
N2P_API_AUTH_URL=https://auth.net2phone.com
N2P_API_N2P_URL=https://api.n2p.io/v2

# ── Optional: linked product URLs ─────────────────────────────────────────────
# Shown in the top-right "Apps & Integrations" dropdown.

N2P_API_PROFILE_SETTINGS=https://profile.prod.n2p.io
N2P_HUDDLE_URL=https://huddle.net2phone.com
N2P_WALLBOARD_URL=https://wallboard.net2phone.com/
N2P_AI_AGENT_URL=https://agent.net2phone.com
N2P_COACH_URL=https://coachai.net2phone.com

# ── Optional: override JWT claim fallbacks ─────────────────────────────────────
# If the net2phone JWT does not embed accountId/userId/clientId in the expected
# claim names, set them here as a fallback (useful for dev/testing accounts).
# NEXT_PUBLIC_ACCOUNT_ID=12345
# NEXT_PUBLIC_USER_ID=67890
# NEXT_PUBLIC_CLIENT_ID=111
